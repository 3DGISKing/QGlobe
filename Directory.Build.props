<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <!-- Prefer externally provided QTDIR/QtDir, but keep a local fallback for IDE IntelliSense. -->
    <QTDIR Condition="'$(QTDIR)'=='' and '$(QtDir)'!=''">$(QtDir)</QTDIR>
    <QTDIR Condition="'$(QTDIR)'=='' and Exists('qt-5.15.18-dynamic-msvc2022-x86_64')">qt-5.15.18-dynamic-msvc2022-x86_64</QTDIR>
  </PropertyGroup>
</Project>
